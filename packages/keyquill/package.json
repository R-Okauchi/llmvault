{
  "name": "keyquill",
  "version": "0.3.0",
  "description": "Bring Your Own Key to any web app — without trusting their server. Browser extension SDK for secure LLM API key management.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "llm",
    "keyquill",
    "openai",
    "anthropic",
    "api-key",
    "browser-extension",
    "security",
    "byok"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R-Okauchi/keyquill.git",
    "directory": "packages/keyquill"
  },
  "homepage": "https://github.com/R-Okauchi/keyquill#readme",
  "bugs": "https://github.com/R-Okauchi/keyquill/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
